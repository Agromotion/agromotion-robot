# AgroMotion Robot - Environment Configuration
# Copy to .env and fill in your values

# ============================================================================
# ROBOT IDENTIFICATION
# ============================================================================
ROBOT_ID=agromotion-robot-01
ROBOT_NAME=AgroMotion Robot

# ============================================================================
# FIREBASE CONFIGURATION
# ============================================================================
FIREBASE_CREDENTIALS_PATH=/home/pi/secrets/firebase-credentials.json
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_PROJECT_ID=your-firebase-project

# ============================================================================
# ARDUINO / SERIAL CONFIGURATION
# ============================================================================
ARDUINO_SERIAL_PORT=/dev/ttyUSB0
ARDUINO_BAUD_RATE=115200

# ============================================================================
# VIDEO STREAMING CONFIGURATION
# ============================================================================
# VIDEO_SOURCE_MODE: "camera" (default) or "video" (file)
# Use "camera" for Raspberry Pi camera (requires libcamera-vid)
# Use "video" for video file playback (requires FFmpeg)
VIDEO_SOURCE_MODE=camera

# VIDEO_FILE_PATH: Path to video file (only used when VIDEO_SOURCE_MODE=video)
# Example: /home/pi/videos/sample.mp4
VIDEO_FILE_PATH=/home/pi/videos/sample.mp4

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
DEBUG_MODE=false
